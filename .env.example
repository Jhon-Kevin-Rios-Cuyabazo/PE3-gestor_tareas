APP_NAME="Gestor de Tareas"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ─── Base de Datos ─────────────────────────────────────────────────────────────
# Producción / Docker: usar MySQL (descomentar y comentar SQLite)
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=gestor_tareas
DB_USERNAME=laravel
DB_PASSWORD=secret

# Desarrollo local rápido (sin Docker): usar SQLite
# DB_CONNECTION=sqlite
# DB_DATABASE=/absolute/path/to/database.sqlite

# ─── Caché / Redis ─────────────────────────────────────────────────────────────
# IMPORTANTE: Cache::tags() requiere un driver que soporte tagging.
# Opciones válidas: redis, memcached, array (solo tests).
# El driver 'database' y 'file' NO soportan tags.
CACHE_STORE=redis
REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─── Sesiones ──────────────────────────────────────────────────────────────────
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# ─── Otros ─────────────────────────────────────────────────────────────────────
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
